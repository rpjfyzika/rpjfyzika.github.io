.kontajner {


  display: flex;
    flex-wrap: wrap;           /* Aby sa to na mobile nezpučilo */
    justify-content: space-between; /* Toto roztiahne stĺpce od okraja po okraj */
    width: 100%;               /* Musí vedieť, že má brať celú šírku */
    max-width: 1400px;         /* Voliteľné: aby to na obrovskom monitore nebolo až príliš ďaleko */
    margin: 0 auto;            /* Vycentruje celú túto plochu na stred */
    padding: 20px;
    box-sizing: border-box;

}


.tema {

display: flex;          /* Zapne flexbox pre celú sekciu */
    flex-direction: column; /* Povie, že nadpis a karta majú byť pod sebou */
    align-items: center;    /* TENTO RIADOK vycentruje nadpis aj kartu na stred */
    margin-bottom: 30px;

}

.karticka {
    background: red;
    border-radius: 15px;
    
    /* RESPONZÍVNA ŠÍRKA */
    width: 90%;          /* Na malom displeji sa zúži */
    max-width: 220px;    /* Na veľkom displeji nebude obrovská */
    
    /* PRUŽNÁ VÝŠKA */
    min-height: 120px;   /* Základná výška */
    height: auto;        /* Ak bude dlhá rovnica, karta sa zväčší */
    
    padding: 15px;       /* Vnútorný odstup, aby text nebol na okraji */
    box-sizing: border-box; /* Dôležité: padding nezväčší kartu navonok */

    /* DOKONALÝ STRED */
    display: flex;
    flex-direction: column;
    justify-content: center; /* Stred zhora nadol */
    align-items: center;     /* Stred zľava doprava - TOTO TI CHÝBA */
    text-align: center;      /* Zarovnanie textu na stred */

margin-bottom: 2rem;
}

</style>


</head>





